#ifdef GL_ES
    #define LOWP lowp
    precision mediump float;
#else
    #define LOWP
#endif

varying LOWP vec4 v_color;
varying vec2 v_texCoords;

uniform sampler2D u_texture;      // спрайт тайла (gp_10.png) — ТОЛЬКО источник формы/силуэта (альфа)
uniform sampler2D u_waterPattern; // реальная бесшовная (repeat-wrap) фотография воды — источник цвета
uniform float u_time;
uniform vec2  u_worldPos; // позиция ТЕКУЩЕГО тайла в сетке карты (см. Editor.drawTile)

// НАСТОЯЩАЯ бесшовная рефракция (см. обсуждение). Раньше пытались искажать саму текстуру тайла
// (gp_10.png) — маленький изолированный ромб внутри прямоугольника с прозрачным полем, у него
// физически нет "пространства", в которое можно безопасно смещаться: любая защита края (проверка
// альфы, плавное затухание) в лучшем случае прятала проблему, но не решала её (швы/резинка).
//
// Теперь источник ЦВЕТА воды — ОТДЕЛЬНАЯ текстура u_waterPattern (assets/shaders/water_pattern.jpg,
// настоящая фотография поверхности воды, GL_REPEAT по обеим осям — см. ShaderLibrary.waterPattern).
// У неё в принципе нет края: она читается в НЕПРЕРЫВНЫХ мировых координатах карты (isoUV, с
// поправкой на изометрическое сжатие 2:1) и просто повторяется бесконечно — соседние тайлы читают
// соседние, стыкующиеся друг с другом участки одной и той же бесшовной поверхности.
//
// Форма/силуэт тайла (альфа) по-прежнему берётся ИСКЛЮЧИТЕЛЬНО из u_texture по НЕИЗМЕНЁННЫМ
// v_texCoords — геометрия ромба жёстко зафиксирована и не может исказиться в принципе.
void main() {
    vec4 shape = texture2D(u_texture, v_texCoords);
    if (shape.a < 0.5) {
        discard;
    }

    // Мировая координата ЭТОГО ПИКСЕЛЯ (тайл + позиция внутри тайла) — непрерывна по всей карте.
    vec2 worldPos = u_worldPos + v_texCoords;

    // Поправка на изометрическое сжатие 2:1 — переводит мировую сетку в диагональную ориентацию,
    // совпадающую с тем, как ромбы реально стоят на экране.
    vec2 isoUV = vec2(
        worldPos.x * 0.5 + worldPos.y,
        -worldPos.x * 0.5 + worldPos.y
    );

    vec2 patternUV = isoUV * 0.35; // масштаб паттерна под дальность обзора камеры (десятки тайлов)

    // Первый слой — "поток", несущий саму текстуру воды в одном направлении.
    vec2 flowUV1 = patternUV + vec2(u_time * 0.05, u_time * 0.02);
    vec3 flow1 = texture2D(u_waterPattern, flowUV1).rgb;

    // Искажение из первого слоя (отклонение от серого — направление "нормали" ряби) применяется
    // ко второму слою — вода искажает сама себя, настоящая рефракция, а не просто наложение.
    vec2 refraction = (flow1.rg - 0.5) * 0.12;

    // Второй слой — финальный цвет: свой масштаб/направление/скорость (не совпадает с первым —
    // не даёт эффекту выглядеть механически повторяющимся) + искажение первого слоя.
    vec2 flowUV2 = patternUV * 1.6 + vec2(-u_time * 0.03, u_time * 0.04) + refraction;
    vec3 waterColor = texture2D(u_waterPattern, flowUV2).rgb;

    gl_FragColor = v_color * vec4(waterColor, shape.a);
}
