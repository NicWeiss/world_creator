#ifdef GL_ES
    #define LOWP lowp
    precision mediump float;
#else
    #define LOWP
#endif

varying LOWP vec4 v_color;
varying vec2 v_texCoords;

uniform sampler2D u_texture;
uniform float u_time;
uniform vec2  u_worldPos; // позиция ТЕКУЩЕГО тайла в сетке карты (не локальные 0..1 UV спрайта)

// Настоящее искажение поверхности (рефракция) — сэмплируем ТУ ЖЕ текстуру по СМЕЩЁННЫМ координатам.
//
// gp_10.png — ПРЯМОУГОЛЬНАЯ текстура с ромбом внутри (изометрия), и ромб занимает её НЕ по центру
// и НЕ симметрично (проверено на пикселях) — прозрачные поля есть не только у краёв прямоугольника
// [0,1], но и по ДИАГОНАЛЬНЫМ граням самого ромба, которые проходят ГДЕ УГОДНО внутри прямоугольника
// в зависимости от строки. Предыдущая защита считала "безопасное" искажение по расстоянию до края
// ПРЯМОУГОЛЬНИКА — неверное допущение, оно не видело диагональные грани ромба и давало тёмные
// "проваливающиеся" пятна вдоль них при боковом смещении.
//
// Правильная защита — проверять альфу РОВНО В ТОЙ смещённой точке, куда мы реально сэмплируем:
// если она уже вне ромба (альфа < 0.5, не важно, у какого именно края прямоугольника/ромба) —
// используем вместо нее исходный (несмещённый, заведомо безопасный) пиксель для этого фрагмента.
void main() {
    vec4 shape = texture2D(u_texture, v_texCoords);
    if (shape.a < 0.5) {
        discard; // мы вне ромба вообще — этого пикселя тут не должно быть
    }

    // Фаза считается от u_worldPos (позиция ТАЙЛА в сетке карты), а НЕ от v_texCoords (те — свои,
    // локальные 0..1 у КАЖДОГО тайла независимо, без связи с соседями). От мировой позиции фаза
    // непрерывна между соседями — рябь на всех тайлах реки/озера складывается в один общий
    // движущийся узор. Единая формула и единая скорость для ВСЕЙ воды (реки/озёра/пруды — без
    // разделения), частота выше, чем раньше — короткая, частая рябь ("речная"), а не редкие
    // широкие волны ("морские").
    vec2 distortion = vec2(
        sin(u_worldPos.y * 0.6 - u_time * 2.2) * 0.020,
        sin(u_worldPos.x * 0.5 - u_time * 2.2) * 0.026
    );

    vec2 distortedUV = v_texCoords + distortion;
    vec4 rippled = texture2D(u_texture, distortedUV);

    // Смещённая точка выборки попала за пределы РЕАЛЬНОГО контура ромба (её альфа < 0.5) — там уже
    // прозрачное поле текстуры, а не вода. Откатываемся к исходному (несмещённому) пикселю вместо
    // того, что бы показать содержимое прозрачной области.
    vec3 color = (rippled.a > 0.5) ? rippled.rgb : shape.rgb;

    gl_FragColor = v_color * vec4(color, 1.0);
}
